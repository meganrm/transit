# Optional runtime route feed URL.
# If not set, the app uses bundled demo data from src/data/routes.ts.
# After running `npm run ingest`, set this to load the generated feed:
# VITE_ROUTES_DATA_URL=/data/routes.feed.json
# Expected payload shapes:
# 1) Route[]
# 2) { "routes": Route[], "sourceLabel"?: string, "generatedAt"?: string }
VITE_ROUTES_DATA_URL=

# Required for traffic data fetch (scripts/fetch-traffic-google.ts).
# Obtain from Google Cloud Console → APIs & Services → Credentials.
# Requires the "Distance Matrix API" to be enabled on the project.
GOOGLE_MAPS_API_KEY=

# King County Metro GTFS static feed URL (scripts/fetch-gtfs.ts).
# Current feed URL (verify at https://kingcounty.gov/en/dept/metro/rider-tools/developer-resources):
# GTFS_URL=https://metro.kingcounty.gov/GTFS/google_transit.zip
GTFS_URL=

# Optional: override the King County ridership Socrata API endpoint (scripts/fetch-ridership.ts).
# Defaults to the known-good URL if unset. Verify at https://data.kingcounty.gov/Transportation
RIDERSHIP_DATASET_URL=
